import { useState, useEffect, useRef } from "react";
import { motion, AnimatePresence, useMotionValue, useTransform } from "framer-motion";
import api from "../api/axios";
import { useTheme } from "../auth/ThemeContext";
import { X, Volume2, VolumeX, BookOpen, GraduationCap, Play, Pause, ChevronRight } from "lucide-react";
import Markdown from "markdown-to-jsx";

const PROFESSOR_POSES = {
    Neutral: "/assets/katarina_neutral.png", // Dr. Aris Aesthetic via filter
    Passionate: "/assets/katarina_assertive.png",
    Pensive: "/assets/katarina_skeptical.png"
};

const avatarVariants = {
    idle: {
        opacity: 1,
        scale: 1,
        y: [0, -12, 0],
        rotate: [0, 1, -1, 0],
        transition: {
            duration: 10,
            repeat: Infinity,
            ease: "easeInOut"
        }
    },
    speaking: {
        opacity: 1,
        scale: [1, 1.03, 1],
        y: [0, -6, 0],
        transition: {
            duration: 0.4,
            repeat: Infinity,
            ease: "easeInOut"
        }
    },
    thinking: {
        rotateX: [4, 8, 4],
        transition: {
            duration: 5,
            repeat: Infinity,
            ease: "easeInOut"
        }
    }
};

export default function LibraryProfessorModal({ topic, onClose }) {
    const { theme } = useTheme();
    const isDark = theme === 'dark';
    const [loading, setLoading] = useState(true);
    const [lecture, setLecture] = useState(null);
    const [isSpeaking, setIsSpeaking] = useState(false);
    const [isMuted, setIsMuted] = useState(false);
    const [imageLoaded, setImageLoaded] = useState(false);
    const [currentView, setCurrentView] = useState('diagram'); // 'diagram', 'notes', 'code'
    const [emotion, setEmotion] = useState("Neutral");

    const synthRef = useRef(window.speechSynthesis);
    const utteranceRef = useRef(null);
    const diagramRef = useRef(null);

    // 3D Parallax Hooks
    const mouseX = useMotionValue(0);
    const mouseY = useMotionValue(0);
    const rotateX = useTransform(mouseY, [-400, 400], [15, -15]);
    const rotateY = useTransform(mouseX, [-400, 400], [-15, 15]);
    const translateZ = useTransform(mouseX, [-400, 400], [20, -20]);

    const handleMouseMove = (e) => {
        const rect = e.currentTarget.getBoundingClientRect();
        mouseX.set(e.clientX - rect.left - rect.width / 2);
        mouseY.set(e.clientY - rect.top - rect.height / 2);
    };

    const fetchLecture = async () => {
        try {
            setLoading(true);
            const res = await api.post("/ai/library/lecture", { topicTitle: topic.title });
            setLecture(res.data);
            setEmotion(res.data.emotion || "Neutral");

            // Render Mermaid diagram if available
            if (res.data.diagram && diagramRef.current) {
                setTimeout(() => {
                    mermaid.initialize({
                        startOnLoad: true,
                        theme: isDark ? 'dark' : 'default',
                        securityLevel: 'loose',
                        themeVariables: {
                            primaryColor: '#6366f1',
                            edgeLabelBackground: isDark ? '#0f1729' : '#ffffff',
                            fontFamily: 'Inter'
                        }
                    });
                    mermaid.run({ nodes: [diagramRef.current] });
                }, 100);
            }

            speak(res.data.voiceScript);
        } catch (err) {
            console.error(err);
        } finally {
            setLoading(false);
        }
    };

    const speak = (text) => {
        if (!synthRef.current || isMuted) return;
        synthRef.current.cancel();

        const utterance = new SpeechSynthesisUtterance(text);

        // Final guard against JSON/Markdown leakage in speech
        utterance.text = text
            .replace(/\{[\s\S]*?\}/g, '') // Remove JSON blocks
            .replace(/[#*_`]/g, '')        // Remove Markdown symbols
            .replace(/\[[\s\S]*?\]/g, '')  // Remove bracket lists
            .trim();

        if (!utterance.text) return;

        const voices = synthRef.current.getVoices();

        // Find academic sounding male voice if possible, else structured female
        let voice = voices.find(v => v.name.includes("Google UK English Male")) ||
            voices.find(v => v.name.includes("Daniel")) ||
            voices.find(v => (v.name.includes("Male") || v.name.includes("male")) && v.lang.startsWith("en"));

        if (voice) utterance.voice = voice;
        utterance.rate = 0.95; // Slightly slower for professorial tone
        utterance.pitch = 0.9; // Lower pitch for authority

        utterance.onstart = () => setIsSpeaking(true);
        utterance.onend = () => setIsSpeaking(false);

        utteranceRef.current = utterance;
        synthRef.current.speak(utterance);
    };

    const toggleVoice = () => {
        if (isSpeaking) {
            synthRef.current.pause();
            setIsSpeaking(false);
        } else {
            if (synthRef.current.paused) {
                synthRef.current.resume();
                setIsSpeaking(true);
            } else if (lecture) {
                speak(lecture.voiceScript);
            }
        }
    };

    useEffect(() => {
        if (topic) fetchLecture();
        return () => {
            if (synthRef.current) synthRef.current.cancel();
        };
    }, [topic]);

    return (
        <div className="fixed inset-0 z-[500] flex items-center justify-center p-6 backdrop-blur-xl bg-black/60">
            <motion.div
                initial={{ opacity: 0, scale: 0.95, y: 20 }}
                animate={{ opacity: 1, scale: 1, y: 0 }}
                className={`w-full max-w-7xl h-[85vh] rounded-[3rem] border flex overflow-hidden transition-all duration-700 ${isDark ? 'bg-slate-950 border-slate-800' : 'bg-white border-slate-200'}`}
            >
                {/* Professor Visual Portal */}
                <div
                    onMouseMove={handleMouseMove}
                    className={`w-1/2 relative flex items-center justify-center p-12 border-r transition-colors ${isDark ? 'bg-slate-900/40 border-slate-800' : 'bg-slate-50 border-slate-100'}`}
                    style={{ perspective: "1500px" }}
                >
                    <div className="absolute top-8 left-12 z-20">
                        <div className="flex items-center gap-4 px-6 py-3 bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-500/20">
                            <GraduationCap className="text-white" size={24} />
                            <div className="flex flex-col">
                                <span className="text-white font-black text-xs uppercase tracking-widest">Professor Dr. Aris</span>
                                <span className="text-indigo-200 text-[8px] font-bold uppercase tracking-widest">IQ 160 // Academic Faculty</span>
                            </div>
                        </div>
                    </div>

                    <motion.div
                        style={{ rotateX, rotateY, transformStyle: "preserve-3d" }}
                        className="relative w-full h-[500px] flex items-center justify-center"
                    >
                        {/* 3D Human Professor Container */}
                        <div className="relative w-full h-full rounded-[4rem] overflow-hidden shadow-[0_100px_200px_rgba(0,0,0,0.8)] z-10 border-8 border-slate-800/20 backdrop-blur-md">
                            {!imageLoaded && (
                                <div className="absolute inset-0 flex items-center justify-center bg-slate-900 flex-col gap-4">
                                    <div className="w-16 h-16 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin" />
                                    <span className="text-[10px] font-black tracking-widest text-indigo-500 uppercase">Calling Faculty Hall...</span>
                                </div>
                            )}

                            <AnimatePresence mode="wait">
                                <motion.img
                                    key={emotion}
                                    src={PROFESSOR_POSES[emotion] || PROFESSOR_POSES.Neutral}
                                    variants={avatarVariants}
                                    animate={isSpeaking ? "speaking" : "idle"}
                                    initial={{ opacity: 0, scale: 1.2, z: 100 }}
                                    transition={{ duration: 1.5, ease: "easeOut" }}
                                    exit={{ opacity: 0, scale: 1.05 }}
                                    onLoad={() => setImageLoaded(true)}
                                    style={{
                                        filter: isDark
                                            ? "sepia(0.25) brightness(0.85) contrast(1.1)"
                                            : "sepia(0.1) brightness(1)",
                                        transformStyle: "preserve-3d",
                                        z: translateZ
                                    }}
                                    className="w-full h-full object-cover"
                                />
                            </AnimatePresence>

                            {/* Scholarly Overlays */}
                            <div className="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent pointer-events-none z-20" />
                            <div className="absolute inset-0 bg-indigo-500/5 mix-blend-overlay z-20" />

                            {/* Scanning/Information Pulse */}
                            <motion.div
                                animate={{ opacity: isSpeaking ? [0.3, 0.6, 0.3] : 0.2 }}
                                transition={{ duration: 2, repeat: Infinity }}
                                className="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-indigo-500/10 to-transparent pointer-events-none z-30"
                            />
                        </div>

                        {/* Parallax Scholarly Elements */}
                        <motion.div
                            style={{
                                x: useTransform(mouseX, [-300, 300], [30, -30]),
                                y: useTransform(mouseY, [-300, 300], [30, -30]),
                                z: -100
                            }}
                            className="absolute -inset-16 rounded-[5rem] border border-white/5 pointer-events-none z-0"
                        />
                    </motion.div>

                    {/* Controls */}
                    <div className="absolute bottom-12 flex items-center gap-6 z-40">
                        <button
                            onClick={toggleVoice}
                            className={`w-16 h-16 rounded-2xl flex items-center justify-center transition-all ${isSpeaking ? 'bg-indigo-600 text-white animate-pulse' : 'bg-slate-800 text-slate-400 hover:text-white'}`}
                        >
                            {isSpeaking ? <Pause size={24} /> : <Play size={24} />}
                        </button>
                        <button
                            onClick={() => setIsMuted(!isMuted)}
                            className="w-12 h-12 rounded-xl bg-slate-800/50 flex items-center justify-center text-slate-400 hover:text-white"
                        >
                            {isMuted ? <VolumeX size={20} /> : <Volume2 size={20} />}
                        </button>
                    </div>
                </div>

                {/* Lecture Board */}
                <div className={`w-1/2 flex flex-col ${isDark ? 'bg-[#0b0f1a]' : 'bg-white'}`}>
                    <div className="p-12 border-b border-white/5 flex justify-between items-center">
                        <div className="flex flex-col gap-1">
                            <span className="text-[10px] font-black text-indigo-500 uppercase tracking-widest">Active Lecture</span>
                            <h3 className="text-2xl font-black uppercase tracking-tight">{topic.title}</h3>
                        </div>
                        <button onClick={onClose} className="p-4 hover:bg-slate-800/50 rounded-2xl transition-all text-slate-500"><X size={24} /></button>
                    </div>

                    <div className="flex-1 overflow-y-auto p-12 custom-scrollbar">
                        {loading ? (
                            <div className="h-full flex flex-col items-center justify-center gap-8 opacity-50">
                                <div className="flex gap-2">
                                    {[0, 1, 2].map(i => (
                                        <motion.div
                                            key={i}
                                            animate={{ scale: [1, 1.5, 1], opacity: [0.3, 1, 0.3] }}
                                            transition={{ duration: 1, repeat: Infinity, delay: i * 0.2 }}
                                            className="w-3 h-3 bg-indigo-500 rounded-full"
                                        />
                                    ))}
                                </div>
                                <span className="text-[10px] font-black uppercase tracking-[0.5em] text-indigo-400">Synthesizing Pedagogical Logic</span>
                            </div>
                        ) : (
                            <motion.div
                                initial={{ opacity: 0 }}
                                animate={{ opacity: 1 }}
                                className={`prose prose-sm md:prose-base transition-colors ${isDark ? 'prose-invert' : 'prose-slate'}`}
                            >
                                <Markdown
                                    className="library-lecture-content font-medium leading-relaxed space-y-8 text-lg"
                                    options={{
                                        overrides: {
                                            h1: { component: ({ children, ...props }) => <h1 className="text-3xl font-black uppercase tracking-tight text-indigo-400 mb-8 mt-12 border-b border-indigo-500/20 pb-4" {...props}>{children}</h1> },
                                            h2: { component: ({ children, ...props }) => <h2 className="text-xl font-black uppercase tracking-widest text-white/90 mb-4 mt-8" {...props}>{children}</h2> },
                                            h3: { component: ({ children, ...props }) => <h3 className="text-lg font-black text-indigo-300 mb-2" {...props}>{children}</h3> },
                                            p: { component: ({ children, ...props }) => <p className="text-slate-400 leading-relaxed mb-6" {...props}>{children}</p> },
                                            ul: { component: ({ children, ...props }) => <ul className="list-none space-y-4 mb-8" {...props}>{children}</ul> },
                                            li: {
                                                component: ({ children, ...props }) => (
                                                    <li className="flex items-start gap-4">
                                                        <ChevronRight className="text-indigo-500 mt-1 shrink-0" size={16} />
                                                        <span className="text-slate-300 font-medium" {...props}>{children}</span>
                                                    </li>
                                                )
                                            },
                                            blockquote: { component: ({ children, ...props }) => <blockquote className="border-l-4 border-indigo-600 bg-indigo-600/5 p-6 rounded-r-2xl italic text-indigo-200" {...props}>{children}</blockquote> }
                                        }
                                    }}
                                >
                                    {lecture?.lectureNote || ""}
                                </Markdown>
                            </motion.div>
                        )}
                    </div>

                    <div className="p-12 border-t border-white/5 bg-slate-900/20">
                        <div className="flex items-center justify-between">
                            <span className="text-[9px] font-black uppercase tracking-[0.3em] text-slate-500 italic">Professor Dr. Aris // Computer Systems Lab</span>
                            <div className="flex gap-1">
                                {[...Array(30)].map((_, i) => (
                                    <motion.div
                                        key={i}
                                        animate={isSpeaking ? { height: [4, 12, 4], opacity: [0.1, 0.4, 0.1] } : { height: 4, opacity: 0.1 }}
                                        transition={{ duration: 0.5, repeat: Infinity, delay: i * 0.05 }}
                                        className="w-1 bg-indigo-500 rounded-full"
                                    />
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </motion.div>
        </div>
    );
}

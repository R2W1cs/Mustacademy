                                        <span className="text-sm font-black text-white group-hover/asset:text-indigo-400 transition-colors flex items-center gap-3">
                                            {cs.title}
                                            {cs.is_hidden && <span className="bg-white text-black text-[7px] px-2 py-0.5 rounded-full uppercase tracking-tighter">PRIVATE</span>}
                                        </span>
                                        <span className="text-[9px] text-slate-500 font-bold uppercase mt-1 tracking-widest">BY {cs.author_name} {cs.user_id === currentUserId && "(YOU)"}</span>
                                    </div>
                                </div>

                                <div className="flex items-center gap-6">
                                    <div className="text-right">
                                        <div className="flex items-center justify-end gap-1 text-[11px] font-black text-indigo-400">
                                            <Star size={12} fill="currentColor" />
                                            <span>{(parseFloat(cs.avg_rating) || 0).toFixed(1)}</span>
                                        </div>
                                    </div>

                                    {cs.user_id === currentUserId && (
                                        <div className="flex gap-2">
                                            <button onClick={(e) => { e.stopPropagation(); onAction('toggle_visibility', cs); }} className={`p - 3 rounded - 2xl transition - all ${cs.is_hidden ? 'bg-indigo-600 text-white' : 'bg-white/5 text-slate-400 hover:bg-white/10'} `}>
                                                {cs.is_hidden ? <Lock size={16} /> : <Eye size={16} />}
                                            </button>
                                            <button onClick={(e) => { e.stopPropagation(); onAction('delete_asset', cs); }} className="p-3 rounded-2xl bg-white/5 text-slate-400 hover:bg-rose-600 hover:text-white transition-all">
                                                <Trash2 size={16} />
                                            </button>
                                        </div>
                                    )}
                                </div>
                            </div>
                        ))}
                        {(!contribData?.cheatsheets || contribData.cheatsheets.length === 0) && (
                            <div className="col-span-2 py-16 text-center border border-dashed border-white/5 rounded-[3rem] bg-white/[0.02]">
                                <p className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em]">Awaiting Scholarly Submissions for your Cohort</p>
                            </div>
                        )}
                    </div>
                    <div className="mt-12 flex justify-center">
                        <div onClick={() => onAction('open_library_feed')} className="inline-flex items-center gap-4 bg-white/5 hover:bg-indigo-600/20 px-10 py-5 rounded-full cursor-pointer transition-all border border-white/5 group/lib active:scale-95">
                            <span className="text-[10px] font-black text-slate-300 uppercase tracking-[0.3em] group-hover/lib:text-white transition-colors">Institutional Library (Cohort Scoped)</span>
                            <span className="text-slate-500 group-hover/lib:text-indigo-400 transition-colors text-lg">→</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    );
};

const CampusChat = ({ activeRoom, currentUser, roomCache, setRoomCache, onClose }) => {
    const [msg, setMsg] = useState("");
    const [messages, setMessages] = useState(roomCache[activeRoom?.id] || []);
    const [members, setMembers] = useState([]);
    const [isVoiceActive, setIsVoiceActive] = useState(false);
    const [passwordRequired, setPasswordRequired] = useState(false);
    const [roomPassword, setRoomPassword] = useState("");
    const chatContainerRef = useRef(null);
    const messagesEndRef = useRef(null);
    const socketRef = useRef(null);
    const audioRef = useRef(new Audio("https://assets.mixkit.co/active_storage/sfx/2354/2354-preview.mp3"));
    const lastProcessedMsgId = useRef(null);
    const fileInputRef = useRef(null);

    // Initialize Socket Connection for this room
    useEffect(() => {
        if (!activeRoom) return;
        let socket;

        try {
            const socketUrl = import.meta.env.VITE_API_URL || "http://localhost:3001";
            socket = io(socketUrl);
            socketRef.current = socket;

            socket.emit("join_room", activeRoom.id);

            socket.on("new_message", (message) => {
                if (!message) return;
                setMessages((prev) => {
                    if (prev.some(m => m.id === message.id)) return prev;

                    // Notification Logic
                    if (currentUser?.id && message.sender_id !== currentUser.id) {
                        if ("Notification" in window && Notification.permission === "granted" && document.hidden) {
                            new Notification(`Message from ${message.sender_name} `, {
                                body: message.text,
                                icon: message.sender_avatar || "/favicon.ico"
                            });
                        }
                        audioRef.current.play().catch(() => { });
                    }

                    const updated = [...prev, message];
                    if (activeRoom) {
                        setRoomCache(cache => ({ ...cache, [activeRoom.id]: updated }));
                    }
                    return updated;
                });
            });

            socket.on("voice_update", ({ userId, isVoiceActive }) => {
                setMembers(prev => prev.map(m => m.id === userId ? { ...m, is_voice_active: isVoiceActive } : m));
            });
        } catch (err) {
            console.error("[SOCKET] Room init error", err);
        }

        return () => {
            if (socket) {
                socket.emit("leave_room", activeRoom.id);
                socket.disconnect();
            }
        };
    }, [activeRoom?.id, currentUser?.id]);

    // Request Notification Permissions
    useEffect(() => {
        if ("Notification" in window && Notification.permission === "default") {
            Notification.requestPermission();
        }
    }, []);

    // Join room & Fetch initial data
    useEffect(() => {
        if (!activeRoom) return;

        api.post(`/ chat / rooms / ${activeRoom.id}/join`, { password: roomPassword })
            .then(() => setPasswordRequired(false))
            .catch(err => {
                if (err.response && err.response.status === 403) setPasswordRequired(true);
            });

        const fetchData = () => {
            if (passwordRequired) return;
            api.get(`/chat/rooms/${activeRoom.id}/messages`)
                .then(res => {
                    setMessages(res.data);
                    if (activeRoom) {
                        setRoomCache(cache => ({ ...cache, [activeRoom.id]: res.data }));
                    }
                })
                .catch(console.error);

            api.get(`/chat/rooms/${activeRoom.id}/members`)
                .then(res => setMembers(res.data))
                .catch(console.error);
        };

        if (!passwordRequired) {
            fetchData();
            const memberInterval = setInterval(() => {
                api.get(`/chat/rooms/${activeRoom.id}/members`)
                    .then(res => setMembers(res.data))
                    .catch(console.error);
            }, 5000);
            return () => clearInterval(memberInterval);
        }
    }, [activeRoom?.id, passwordRequired, roomPassword]);

    // Scroll to bottom
    useEffect(() => {
        if (chatContainerRef.current) {
            chatContainerRef.current.scrollTop = chatContainerRef.current.scrollHeight;
        }
    }, [messages]);

    const toggleVoice = async () => {
        try {
            if (!isVoiceActive) {
                await navigator.mediaDevices.getUserMedia({ audio: true });
            }
            setIsVoiceActive(!isVoiceActive);
            api.put(`/chat/rooms/${activeRoom.id}/voice`, { isVoiceActive: !isVoiceActive }).catch(console.error);
        } catch (err) {
            alert("Microphone access is required for Voice Protocol.");
        }
    };

    const sendMessage = async (text, attachmentUrl = null, attachmentType = null) => {
        if (!text && !attachmentUrl) return;

        const optimisticMsg = {
            id: Date.now(),
            sender_id: currentUser?.id,
            sender_name: 'Me',
            text: text || '',
            attachment_url: attachmentUrl,
            attachment_type: attachmentType,
            created_at: new Date().toISOString(),
            isOptimistic: true
        };

        setMessages(prev => [...prev, optimisticMsg]);
        setMsg("");

        try {
            const res = await api.post(`/chat/rooms/${activeRoom.id}/messages`, { text, attachmentUrl, attachmentType });
            setMessages(prev => {
                const updated = prev.map(m => m.id === optimisticMsg.id ? res.data : m);
                if (activeRoom) {
                    setRoomCache(cache => ({ ...cache, [activeRoom.id]: updated }));
                }
                return updated;
            });
            lastProcessedMsgId.current = res.data.id;
        } catch (err) {
            setMessages(prev => prev.filter(m => m.id !== optimisticMsg.id));
            alert("Message failed to transmit.");
        }
    };

    const handleFileUpload = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const formData = new FormData();
        formData.append('file', file);
        try {
            const res = await api.post('/chat/upload', formData, { headers: { 'Content-Type': 'multipart/form-data' } });
            await sendMessage(null, res.data.url, res.data.type);
        } catch (err) {
            alert("Asset upload failed.");
        }
    };

    const handlePasswordSubmit = () => {
        api.post(`/chat/rooms/${activeRoom.id}/join`, { password: roomPassword })
            .then(() => setPasswordRequired(false))
            .catch(() => alert("Access Denied: Invalid Security Key"));
    };

    return (
        <motion.div
            initial={{ scale: 0.95, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            className="bg-[#05050a] rounded-[2.5rem] w-[90vw] h-[90vh] flex shadow-2xl relative overflow-hidden border border-white/5"
        >
            {passwordRequired && (
                <div className="absolute inset-0 z-50 bg-[#03040b]/95 backdrop-blur-xl flex flex-col items-center justify-center p-12 text-center text-white">
                    <div className="mb-8 p-6 rounded-full bg-white/5 text-indigo-500">
                        <Lock size={64} />
                    </div>
                    <h3 className="text-4xl font-black uppercase tracking-tightest mb-4 outline-glow">Restricted Sector</h3>
                    <p className="text-slate-400 font-bold mb-10 text-lg">Enter security key to access {activeRoom?.name}</p>
                    <input
                        type="password"
                        value={roomPassword}
                        onChange={e => setRoomPassword(e.target.value)}
                        className="bg-white/5 border border-white/10 rounded-2xl px-10 py-5 text-center font-black text-2xl mb-8 outline-none focus:border-indigo-500 transition-all w-full max-w-sm text-white"
                        placeholder="KEY..."
                    />
                    <div className="flex gap-6">
                        <button onClick={onClose} className="px-12 py-4 rounded-2xl font-black uppercase tracking-widest bg-white/5 hover:bg-white/10 transition-all text-[10px]">Abort</button>
                        <button onClick={handlePasswordSubmit} className="px-12 py-4 rounded-2xl font-black uppercase tracking-widest bg-indigo-600 hover:bg-indigo-500 transition-all shadow-2xl text-[10px]">Access</button>
                    </div>
                </div>
            )}

            {/* 1. Main Chat Area */}
            <div className="flex-1 flex flex-col h-full relative z-10 border-r border-white/5">
                {/* Header */}
                <div className="p-8 border-b border-white/5 flex items-center justify-between bg-[#0a0c20]/60 backdrop-blur-xl z-20">
                    <div className="flex items-center gap-6">
                        <div className="w-14 h-14 rounded-2xl bg-indigo-500/10 text-indigo-400 flex items-center justify-center font-black text-2xl border border-indigo-500/20 shadow-inner">
                            #
                        </div>
                        <div>
                            <h3 className="font-black text-white uppercase tracking-tightest text-2xl">{activeRoom?.name}</h3>
                            <p className="text-[10px] text-slate-500 font-black uppercase tracking-[0.3em] flex items-center gap-3 mt-1">
                                {activeRoom?.type === 'private' ? '🔒 Private Study Sector' : '🌍 Public Campus Lounge'}
                            </p>
                        </div>
                    </div>

                    <div className="flex gap-4 items-center">
                        <button
                            onClick={toggleVoice}
                            className={`flex items-center gap-3 px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all
                 ${isVoiceActive ? 'bg-emerald-500 text-white shadow-2xl animate-pulse' : 'bg-white/5 text-slate-400 hover:bg-white/10 border border-white/5'}
               `}
                        >
                            <Mic size={16} />
                            {isVoiceActive ? 'Connected' : 'Connect Voice'}
                        </button>
                        <button onClick={onClose} className="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 text-slate-500 hover:bg-rose-600 hover:text-white transition-all font-black border border-white/5">
                            <X size={20} />
                        </button>
                    </div>
                </div>

                {/* Messages */}
                <div ref={chatContainerRef} className="flex-1 overflow-y-auto p-10 space-y-6 bg-[#03040b] scrollbar-thin scrollbar-thumb-white/5 scrollbar-track-transparent">
                    {messages.length === 0 && (
                        <div className="h-full flex flex-col items-center justify-center opacity-10">
                            <div className="mb-8">
                                <MessageSquare size={96} />
                            </div>
                            <p className="font-black uppercase tracking-[0.5em] text-2xl text-white">Quiet Sector</p>
                            <p className="text-sm font-bold text-slate-400 mt-2">Initiate scholarly transmission.</p>
                        </div>
                    )}
                    {messages.map((m, i) => (
                        <div key={m.id || i} className={`flex gap-5 group ${m.sender_id === currentUser?.id ? 'flex-row-reverse' : ''}`}>
                            <div className="w-12 h-12 rounded-2xl bg-[#0a0c20] border-2 border-white/5 shadow-2xl overflow-hidden flex-shrink-0">
                                {m.sender_avatar ? <img src={m.sender_avatar} className="w-full h-full object-cover" /> : <div className="w-full h-full flex items-center justify-center text-[10px] font-black text-white">{m.sender_name?.[0]}</div>}
                            </div>
                            <div className={`max-w-[75%]`}>
                                <div className={`flex items-baseline gap-3 mb-2 ${m.sender_id === currentUser?.id ? 'justify-end' : ''}`}>
                                    <span className="text-[11px] font-black text-white cursor-pointer hover:text-indigo-400 transition-colors uppercase tracking-widest">
                                        {m.sender_id === currentUser?.id ? 'Me' : m.sender_name}
                                    </span>
                                    <span className="text-[9px] font-bold text-slate-600 tracking-tighter">{new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
                                </div>
                                <div className={`p-5 rounded-[1.5rem] text-sm font-medium leading-relaxed shadow-2xl transition-all border
                      ${m.sender_id === currentUser?.id ? 'bg-indigo-600/90 text-white rounded-tr-none border-indigo-400/20' : 'bg-white/5 text-slate-200 rounded-tl-none border-white/5 group-hover:bg-white/[0.08]'}
                      ${m.isOptimistic ? 'opacity-50 italic' : ''}
                    `}>
                                    {m.text}
                                    {m.isOptimistic && <span className="ml-3 text-[8px] font-black opacity-30 uppercase tracking-widest">Transmitting...</span>}
                                </div>
                            </div>
                        </div>
                    ))}
                    <div ref={messagesEndRef} />
                </div>

                {/* Input */}
                <div className="p-8 bg-[#0a0c20]/40 border-t border-white/5">
                    <div className="flex gap-6 items-center bg-black/40 border border-white/10 p-3 rounded-[2.5rem] focus-within:border-indigo-500/50 transition-all shadow-inner">
                        <button
                            onClick={() => fileInputRef.current.click()}
                            className="w-12 h-12 rounded-full bg-white/5 text-slate-400 hover:text-white flex items-center justify-center font-black shadow-2xl transition-all border border-white/5"
                        >
                            <Paperclip size={20} />
                        </button>
                        <input type="file" ref={fileInputRef} className="hidden" onChange={handleFileUpload} />
                        <input
                            type="text"
                            value={msg}
                            onChange={(e) => setMsg(e.target.value)}
                            onKeyDown={(e) => {
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    sendMessage(msg);
                                }
                            }}
                            placeholder={`Transmit message to #${activeRoom?.name}...`}
                            className="flex-1 bg-transparent border-none outline-none font-bold text-white placeholder:text-slate-600 h-14 text-sm"
                        />
                        <button
                            onClick={() => sendMessage(msg)}
                            className="px-10 h-12 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-white hover:text-slate-900 transition-all shadow-2xl"
                        >
                            Send
                        </button>
                    </div>
                </div>
            </div>

            {/* 2. Members Sidebar */}
            <div className="w-80 bg-[#0a0c20]/20 hidden md:flex flex-col h-full p-6">
                <div className="mb-8 p-4">
                    <h4 className="font-black text-[10px] text-slate-500 uppercase tracking-[0.3em]">Online Scholars — {members.length}</h4>
                </div>
                <div className="flex-1 overflow-y-auto space-y-2 scrollbar-hide px-2">
                    {members.map(member => (
                        <div key={member.id} className="flex items-center gap-4 p-3 rounded-2xl hover:bg-white/5 transition-all cursor-pointer group border border-transparent hover:border-white/5">
                            <div className="relative">
                                <div className="w-11 h-11 rounded-2xl bg-indigo-500/10 overflow-hidden border border-white/10 shadow-inner">
                                    {member.avatar_url ? <img src={member.avatar_url} className="w-full h-full object-cover" /> : <div className="w-full h-full flex items-center justify-center text-[10px] font-black text-white">{member.username?.[0]}</div>}
                                </div>
                                {member.is_voice_active && <div className="absolute -bottom-1 -right-1 bg-emerald-500 p-1.5 rounded-full border-2 border-[#05050a]"><div className="w-1.5 h-1.5 bg-white rounded-full animate-pulse" /></div>}
                            </div>
                            <div className="leading-tight">
                                <p className="text-[13px] font-black text-slate-300 group-hover:text-white transition-colors">{member.username}</p>
                                {member.is_voice_active && <p className="text-[9px] font-black text-emerald-400 uppercase tracking-[0.2em] mt-0.5">Speaking</p>}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </motion.div>
    );
};

const RoomCreator = ({ onClose, onCreated }) => {
    const [name, setName] = useState("");
    const [type, setType] = useState("public");
    const [password, setPassword] = useState("");

    const handleCreate = async () => {
        if (!name.trim()) return;
        if (type === 'private' && !password.trim()) {
            alert("Private sectors require a security key.");
            return;
        }
        try {
            await api.post("/chat/rooms", { name, type, password });
            onCreated();
        } catch (err) {
            console.error(err);
        }
    };

    return (
        <div className="bg-[#0a0c20] p-10 rounded-[3rem] max-w-sm w-full shadow-2xl border border-white/10">
            <h3 className="text-2xl font-black text-white mb-8 uppercase tracking-tightest">Construct Room</h3>
            <div className="space-y-6">
                <div>
                    <label className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-3 block px-1">Room Name</label>
                    <input
                        value={name} onChange={e => setName(e.target.value)}
                        className="w-full bg-white/5 font-black text-white p-5 rounded-2xl border border-white/10 outline-none focus:border-indigo-500 transition-all text-sm"
                        placeholder="e.g. Late Night Java"
                    />
                </div>
                <div>
                    <label className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-3 block px-1">Privacy Level</label>
                    <div className="flex gap-4">
                        <button onClick={() => setType('public')} className={`flex-1 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2 ${type === 'public' ? 'bg-indigo-600 text-white shadow-2xl' : 'bg-white/5 text-slate-400 hover:bg-white/10'}`}>
                            <Globe size={14} /> Public
                        </button>
                        <button onClick={() => setType('private')} className={`flex-1 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2 ${type === 'private' ? 'bg-white text-slate-900 shadow-2xl' : 'bg-white/5 text-slate-400 hover:bg-white/10'}`}>
                            <Lock size={14} /> Private
                        </button>
                    </div>
                </div>

                {type === 'private' && (
                    <motion.div initial={{ height: 0, opacity: 0 }} animate={{ height: 'auto', opacity: 1 }}>
                        <label className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-3 block px-1">Security Key</label>
                        <input
                            type="password"
                            value={password} onChange={e => setPassword(e.target.value)}
                            className="w-full bg-white/5 font-black text-white p-5 rounded-2xl border border-white/10 outline-none focus:border-indigo-500 transition-all text-sm"
                            placeholder="Required for entry..."
                        />
                    </motion.div>
                )}

                <button onClick={handleCreate} className="w-full py-5 mt-4 bg-emerald-600 text-white font-black text-[10px] uppercase tracking-[0.3em] rounded-2xl hover:bg-white hover:text-emerald-600 transition-all shadow-2xl active:scale-95">
                    Initialize Sector
                </button>
            </div>
        </div>
    );
};

const CampusLounge = ({ onSelectRoom, onlineScholars = [] }) => {
    const [rooms, setRooms] = useState([]);
    const [showCreator, setShowCreator] = useState(false);
    const [activeTab, setActiveTab] = useState('lounge');

    const fetchRooms = () => {
        api.get("/chat/rooms").then(res => setRooms(res.data)).catch(console.error);
    };

    useEffect(() => {
        fetchRooms();
        const interval = setInterval(fetchRooms, 10000);
        return () => clearInterval(interval);
    }, []);

    const handleStartDM = async (peerId) => {
        try {
            const res = await api.post('/chat/dm', { peerId });
            onSelectRoom(res.data);
        } catch (err) {
            alert("Could not establish private line.");
        }
    };

    return (
        <div className="studio-card p-10 h-full flex flex-col items-start w-full relative group min-h-[500px]">
            {/* Header Tabs */}
            <div className="flex items-center gap-8 mb-8 border-b border-white/5 w-full pb-6">
                <button
                    onClick={() => setActiveTab('lounge')}
                    className={`text-[11px] font-black uppercase tracking-[0.4em] transition-all relative ${activeTab === 'lounge' ? 'text-indigo-400' : 'text-slate-500 hover:text-slate-300'}`}
                >
                    Lounge
                    {activeTab === 'lounge' && <motion.div layoutId="loungeTab" className="absolute -bottom-[25px] left-0 right-0 h-0.5 bg-indigo-400" />}
                </button>
                <button
                    onClick={() => setActiveTab('scholars')}
                    className={`text-[11px] font-black uppercase tracking-[0.4em] transition-all relative ${activeTab === 'scholars' ? 'text-indigo-400' : 'text-slate-500 hover:text-slate-300'}`}
                >
                    Scholars ({onlineScholars.length})
                    {activeTab === 'scholars' && <motion.div layoutId="loungeTab" className="absolute -bottom-[25px] left-0 right-0 h-0.5 bg-indigo-400" />}
                </button>
            </div>

            {activeTab === 'lounge' ? (
                <>
                    <div className="flex justify-between items-center w-full mb-8">
                        <p className="text-[9px] text-slate-500 font-black uppercase tracking-[0.4em]">Active Sectors</p>
                        <button onClick={() => setShowCreator(true)} className="w-10 h-10 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-indigo-600 hover:border-indigo-400 transition-all font-black shadow-2xl active:scale-90 text-2xl">
                            +
                        </button>
                    </div>

                    <div className="flex-1 w-full space-y-4 overflow-y-auto scrollbar-hide pr-2">
                        {rooms.map(room => (
                            <div
                                key={room.id}
                                onClick={() => onSelectRoom(room)}
                                className="w-full p-6 rounded-[2rem] bg-indigo-500/5 border border-white/5 hover:border-indigo-500/40 hover:bg-indigo-500/10 transition-all cursor-pointer group/room flex justify-between items-center shadow-xl mb-2"
                            >
                                <div className="flex items-center gap-5">
                                    <div className="w-12 h-12 rounded-2xl bg-[#0a0c20] border border-white/10 flex items-center justify-center text-xl text-slate-600 group-hover/room:text-indigo-400 group-hover/room:border-indigo-500/30 transition-all font-black shadow-inner">#</div>
                                    <div>
                                        <p className="font-black text-white text-md group-hover/room:text-indigo-300 transition-colors uppercase tracking-tight">{room.name}</p>
                                        <p className="text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] mt-1">
                                            {room.type} • {room.member_count} scholars
                                        </p>
                                    </div>
                                </div>
                                {room.voice_count > 0 && (
                                    <div className="flex items-center gap-2 text-[9px] font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-4 py-2 rounded-full shadow-inner animate-pulse">
                                        <Mic size={12} /> {room.voice_count}
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </>
            ) : (
                <>
                    <div className="flex justify-between items-center w-full mb-8">
                        <p className="text-[9px] text-slate-500 font-black uppercase tracking-[0.4em]">Online Peers</p>
                    </div>
                    <div className="flex-1 w-full space-y-4 overflow-y-auto scrollbar-hide pr-2">
                        {onlineScholars.map(scholar => (
                            <div
                                key={scholar.id}
                                onClick={() => handleStartDM(scholar.id)}
                                className="flex items-center gap-5 p-5 rounded-[2.5rem] bg-white/5 border border-white/5 hover:bg-white/[0.08] hover:border-indigo-500/30 transition-all cursor-pointer group shadow-xl"
                            >
                                <div className="w-14 h-14 rounded-[1.5rem] bg-indigo-500/10 border border-white/10 overflow-hidden shadow-inner flex-shrink-0 relative">
                                    {scholar.avatar_url ? <img src={scholar.avatar_url} className="w-full h-full object-cover" /> : <div className="w-full h-full flex items-center justify-center font-black text-white text-lg">{scholar.name?.[0]}</div>}
                                    <div className="absolute bottom-1 right-1 w-3.5 h-3.5 bg-emerald-500 rounded-full border-4 border-[#0a0c20]" />
                                </div>
                                <div className="flex-1 min-w-0">
                                    <p className="text-md font-black text-white group-hover:text-indigo-400 transition-colors truncate uppercase tracking-tight">{scholar.name}</p>
                                    <p className="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">Cohorts Member</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </>
            )}

            <AnimatePresence>
                {showCreator && (
                    <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-xl p-4">
                        <RoomCreator onClose={() => setShowCreator(false)} onCreated={() => { fetchRooms(); setShowCreator(false); }} />
                    </div>
                )}
            </AnimatePresence>
        </div>
    );
};

const ScholarlyProtocolModal = ({ type, onClose, onSubmitted }) => {
    const [title, setTitle] = useState("");
    const [file, setFile] = useState(null);
    const [loading, setLoading] = useState(false);
    const fileInputRef = useRef(null);

    const handleSubmit = async () => {
        if (!file) return;
        setLoading(true);
        try {
            const formData = new FormData();
            formData.append('file', file);
            const uploadRes = await api.post('/chat/upload', formData, {
                headers: { 'Content-Type': 'multipart/form-data' }
            });

            const assetType = type === 'upload_summary' ? 'summary' : 'cheatsheet';
            await api.post(`/contributions/${assetType}`, {
                title: title || file.name,
                fileUrl: uploadRes.data.url,
                assetType: assetType,
                subjectArea: "General Scholarly"
            });

            onSubmitted();
        } catch (err) {
            alert("Scholarly transfer failed via native protocol.");
        } finally {
            setLoading(false);
        }
    };

    return (
        <motion.div
            initial={{ scale: 0.95, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            className="bg-[#0a0c20] rounded-[3rem] p-12 max-w-md w-full shadow-2xl relative overflow-hidden border border-white/10"
        >
            <div className="absolute top-0 left-0 w-full h-2 bg-indigo-500 shadow-[0_0_20px_rgba(99,102,241,0.4)]"></div>
            <button onClick={onClose} className="absolute top-8 right-8 text-slate-500 hover:text-white font-black transition-all">
                <X size={24} />
            </button>

            <h2 className="text-4xl font-black text-white mb-3 uppercase tracking-tightest outline-glow">
                {type === 'upload_summary' ? "Summary Protocol" : "Knowledge Transfer"}
            </h2>
            <p className="text-[10px] text-indigo-400 font-black uppercase tracking-[0.4em] mb-10 text-center sm:text-left">
                Institutional Asset Exchange
            </p>

            <div className="space-y-8">
                <div>
                    <label className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] block mb-3 px-1">Asset Designation</label>
                    <input
                        type="text"
                        className="w-full p-5 rounded-2xl bg-white/5 border border-white/5 outline-none focus:border-indigo-500 transition-all font-black text-white placeholder:text-slate-700 text-sm"
                        placeholder={type === 'upload_summary' ? "e.g. Adv. React Summary" : "e.g. Neural Networks Cheatsheet"}
                        value={title}
                        onChange={(e) => setTitle(e.target.value)}
                    />
                </div>

                <div
                    onClick={() => fileInputRef.current.click()}
                    className="border-2 border-dashed border-white/5 rounded-3xl p-12 flex flex-col items-center justify-center cursor-pointer hover:border-indigo-500/50 hover:bg-white/5 transition-all group"
                >
                    <input
                        type="file"
                        ref={fileInputRef}
                        className="hidden"
                        onChange={(e) => setFile(e.target.files[0])}
                        accept=".pdf,.doc,.docx,.txt"
                    />
                    <div className="w-20 h-20 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-4xl mb-6 group-hover:scale-110 transition-transform shadow-inner border border-indigo-500/20">
                        {file ? <FileText size={40} /> : <Upload size={40} />}
                    </div>
                    <p className="text-xs font-black text-white uppercase tracking-widest mb-2 text-center">
                        {file ? file.name : "Import from Device"}
                    </p>
                    <p className="text-[9px] text-slate-500 font-black uppercase tracking-[0.2em] text-center">
                        {file ? `${(file.size / 1024).toFixed(1)} KB` : "Browse PDF, DOC, TXT"}
                    </p>
                </div>

                <button
                    onClick={handleSubmit}
                    disabled={loading || !file}
                    className="w-full py-6 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.3em] hover:bg-white hover:text-indigo-600 transition-all disabled:opacity-50 shadow-2xl active:scale-95"
                >
                    {loading ? "Initializing Transfer..." : `Push to Institutional Library`}
                </button>
            </div>
        </motion.div>
    );
};

const ReviewAssetModal = ({ asset, onClose, onSubmitted }) => {
    const [rating, setRating] = useState(5);
    const [comment, setComment] = useState("");
    const [loading, setLoading] = useState(false);
    const [showViewer, setShowViewer] = useState(false);

    const handleSubmit = async () => {
        setLoading(true);
        try {
            await api.post('/contributions/review', {
                assetId: asset.id,
                rating,
                comment
            });
            onSubmitted();
        } catch (err) {
            alert(err.response?.data?.message || "Review submission failed.");
        } finally {
            setLoading(false);
        }
    };

    return (
        <motion.div
            initial={{ scale: 0.95, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            className="bg-[#0a0c20] rounded-[3rem] p-12 max-w-md w-full shadow-2xl relative overflow-hidden border border-white/10"
        >
            <button onClick={onClose} className="absolute top-8 right-8 text-slate-500 hover:text-white font-black transition-all">
                <X size={24} />
            </button>

            <h2 className="text-3xl font-black text-white mb-2 uppercase tracking-tightest outline-glow">Peer Review</h2>
            <p className="text-[10px] text-indigo-400 font-black uppercase tracking-[0.3em] mb-10">Evaluating: {asset.title}</p>

            <div className="space-y-8">
                <div>
                    <label className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-5 block px-1">Scholarly Quality (1-5)</label>
                    <div className="flex justify-between gap-3">
                        {[1, 2, 3, 4, 5].map(nu => (
                            <button
                                key={nu}
                                onClick={() => setRating(nu)}
                                className={`w-14 h-14 rounded-2xl font-black text-xl transition-all shadow-2xl ${rating === nu ? 'bg-indigo-600 text-white border-2 border-indigo-400/50' : 'bg-white/5 text-slate-500 border border-white/5 hover:border-white/10'}`}
                            >
                                {nu}
                            </button>
                        ))}
                    </div>
                </div>

                <div>
                    <label className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-3 block px-1">Critique / Insight</label>
                    <textarea
                        value={comment}
                        onChange={e => setComment(e.target.value)}
                        className="w-full bg-white/5 rounded-2xl p-5 text-sm font-black text-white border border-white/5 outline-none focus:border-indigo-500 h-40 placeholder:text-slate-700"
                        placeholder="Add scholarly feedback..."
                    />
                </div>

                <div className="flex gap-4 pt-2">
                    <button
                        onClick={() => setShowViewer(true)}
                        className="flex-1 py-5 bg-[#03040b] text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.3em] hover:bg-white hover:text-slate-900 transition-all shadow-2xl border border-white/5"
                    >
                        Open Viewer
                    </button>
                    <button
                        onClick={handleSubmit}
                        disabled={loading}
                        className="flex-1 py-5 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.3em] hover:bg-white hover:text-indigo-600 transition-all shadow-2xl active:scale-95"
                    >
                        {loading ? "Syncing..." : "Submit Review"}
                    </button>
                </div>
            </div>

            <AnimatePresence>
                {showViewer && (
                    <div className="fixed inset-0 z-[100] bg-[#03040b]/95 backdrop-blur-2xl flex flex-col p-12">
                        <div className="flex justify-between items-center mb-8">
                            <h3 className="text-white font-black uppercase tracking-[0.4em] text-sm">{asset.title}</h3>
                            <button onClick={() => setShowViewer(false)} className="bg-white/5 hover:bg-rose-600 text-white px-10 py-3 rounded-2xl font-black text-[10px] tracking-widest transition-all border border-white/10">CLOSE VIEWER</button>
                        </div>
                        <div className="flex-1 bg-white rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white/5">
                            <iframe src={asset.file_url} className="w-full h-full border-none" title="Asset Viewer" />
                        </div>
                    </div>
                )}
            </AnimatePresence>
        </motion.div>
    );
};

const LibraryFullFeedModal = ({ assets, onClose, onReview, currentUserId, onAction }) => {
    const [filter, setFilter] = useState("");
    const filteredAssets = assets.filter(a => a.title.toLowerCase().includes(filter.toLowerCase()) || a.author_name.toLowerCase().includes(filter.toLowerCase()));

    return (
        <motion.div
            initial={{ opacity: 0, y: 50 }}
            animate={{ opacity: 1, y: 0 }}
            className="bg-[#05050a] rounded-[3rem] w-full max-w-6xl h-[90vh] shadow-2xl border border-white/5 flex flex-col overflow-hidden"
            onClick={(e) => e.stopPropagation()}
        >
            <div className="p-12 border-b border-white/5 flex justify-between items-center bg-[#0a0c20]/80 backdrop-blur-xl">
                <div>
                    <p className="text-[10px] font-black uppercase tracking-[0.4em] text-indigo-400 mb-2">Institutional Archive</p>
                    <h2 className="text-3xl font-black tracking-tightest text-white outline-glow">Scholarly Library</h2>
                </div>
                <div className="flex items-center gap-10">
                    <div className="relative">
                        <div className="absolute left-6 top-1/2 -translate-y-1/2 text-slate-500">
                            <Search size={18} />
                        </div>
                        <input
                            type="text"
                            placeholder="Designation Search..."
                            className="bg-white/5 border border-white/10 rounded-[1.5rem] py-5 pl-16 pr-10 text-[11px] font-black outline-none focus:border-indigo-500 transition-all w-80 text-white placeholder:text-slate-600 uppercase tracking-widest"
                            value={filter}
                            onChange={e => setFilter(e.target.value)}
                        />
                    </div>
                    <button onClick={onClose} className="text-slate-500 hover:text-white font-black text-2xl transition-all">
                        <X size={24} />
                    </button>
                </div>
            </div>

            <div className="flex-1 overflow-y-auto p-12 bg-[#03040b] scrollbar-thin scrollbar-thumb-white/5 scrollbar-track-transparent">
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                    {filteredAssets.map(asset => (
                        <div
                            key={asset.id}
                            className={`bg-[#0a0c20]/40 p-10 rounded-[3rem] border border-white/5 hover:border-indigo-500/50 hover:shadow-[0_0_50px_rgba(99,102,241,0.1)] transition-all group relative overflow-hidden backdrop-blur-sm ${asset.is_hidden ? 'opacity-50 contrast-75' : ''}`}
                        >
                            <div
                                onClick={() => onReview(asset)}
                                className="cursor-pointer relative z-10"
                            >
                                <div className="w-16 h-16 rounded-[1.5rem] bg-white/5 border border-white/5 flex items-center justify-center text-4xl mb-8 group-hover:scale-110 transition-all shadow-inner">
                                    {asset.asset_type === 'summary' ? <BookOpen size={32} /> : <FileText size={32} />}
                                </div>
                                <h4 className="font-black text-white text-xl mb-2 tracking-tight group-hover:text-indigo-400 transition-colors flex items-center gap-3 uppercase">
                                    {asset.title}
                                    {asset.is_hidden && <span className="bg-indigo-500 text-white text-[8px] px-3 py-1 rounded-full uppercase tracking-widest shadow-lg">PRIVATE</span>}
                                </h4>
                                <p className="text-[10px] font-black uppercase tracking-[0.3em] text-slate-600 mb-8 border-l-2 border-indigo-500/30 pl-3">By {asset.author_name} {asset.user_id === currentUserId && "(YOU)"}</p>
                            </div>

                            <div className="flex justify-between items-center pt-8 border-t border-white/5 relative z-10">
                                <div className="flex flex-col">
                                    <div className="flex items-center gap-2 text-[13px] font-black text-indigo-400">
                                        <span className="text-yellow-500">★</span>
                                        <span>{(parseFloat(asset.avg_rating) || 0).toFixed(1)}</span>
                                    </div>
                                    <span className="text-[9px] font-black text-slate-700 uppercase tracking-widest mt-1">{asset.review_count} Reviews</span>
                                </div>

                                <div className="flex gap-3">
                                    {asset.user_id === currentUserId && (
                                        <>
                                            <button
                                                onClick={() => onAction('hide_from_specific', asset)}
                                                className="p-4 bg-white/5 text-slate-500 rounded-2xl hover:bg-rose-600 hover:text-white transition-all text-xs border border-white/5"
                                                title="Hide from specific student"
                                            >
                                                <Lock size={16} />
                                            </button>
                                            <button
                                                onClick={() => onAction('toggle_visibility', asset)}
                                                className={`p-4 rounded-2xl transition-all text-xs border border-white/5 ${asset.is_hidden ? 'bg-indigo-600 text-white' : 'bg-white/5 text-slate-500 hover:bg-indigo-500/20 hover:text-indigo-400'}`}
                                            >
                                                {asset.is_hidden ? <Folder size={16} /> : <Eye size={16} />}
                                            </button>
                                            <button
                                                onClick={() => onAction('delete_asset', asset)}
                                                className="p-4 bg-white/5 text-slate-500 rounded-2xl hover:bg-rose-600 hover:text-white transition-all text-xs border border-white/5"
                                            >
                                                <Trash2 size={16} />
                                            </button>
                                        </>
                                    )}
                                    <button
                                        onClick={() => onReview(asset)}
                                        className="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-white hover:text-indigo-600 transition-all shadow-2xl"
                                    >
                                        View
                                    </button>
                                </div>
                            </div>
                            <div className="absolute -bottom-10 -right-10 w-40 h-40 bg-indigo-500/5 rounded-full blur-3xl group-hover:bg-indigo-500/10 transition-all"></div>
                        </div>
                    ))}
                    {filteredAssets.length === 0 && (
                        <div className="col-span-full py-40 text-center">
                            <p className="text-slate-600 font-black uppercase tracking-[0.5em] text-lg opacity-20">No matching assets found.</p>
                        </div>
                    )}
                </div>
            </div>
        </motion.div>
    );
};

/* ---------------- MAIN DASHBOARD ---------------- */

const Dashboard = () => {

    // Motion Values for Performance (Replaces state-based mousePos)
    const mouseX = useMotionValue(0);
    const mouseY = useMotionValue(0);

    // Smooth rotation values derived from mouse position
    const rotateX = useSpring(useTransform(mouseY, [0, window.innerHeight], [2, -2]), { stiffness: 50, damping: 20 });
    const rotateY = useSpring(useTransform(mouseX, [0, window.innerWidth], [-2, 2]), { stiffness: 50, damping: 20 });

    // Specific rotation intensities for different layers (if needed)
    const rotateX_intense = useSpring(useTransform(mouseY, [0, window.innerHeight], [4, -4]), { stiffness: 50, damping: 20 });
    const rotateY_intense = useSpring(useTransform(mouseX, [0, window.innerWidth], [-4, 4]), { stiffness: 50, damping: 20 });

    // Background Parallax
    const bgX = useTransform(mouseX, [0, window.innerWidth], [-20, 20]);
    const bgY = useTransform(mouseY, [0, window.innerHeight], [-20, 20]);

    useEffect(() => {
        const handleMouseMove = (e) => {
            // Direct updates to motion values - NO RE-RENDERS
            mouseX.set(e.clientX);
            mouseY.set(e.clientY);
        };
        window.addEventListener('mousemove', handleMouseMove);
        return () => window.removeEventListener('mousemove', handleMouseMove);
    }, []);

    // UI States
    const [showAdvisor, setShowAdvisor] = useState(false);
    const [activeProtocolModal, setActiveProtocolModal] = useState(null);
    const [selectedAssetForReview, setSelectedAssetForReview] = useState(null);
    const [showLibraryFeed, setShowLibraryFeed] = useState(false);
    const [activeChatPeer, setActiveChatPeer] = useState(null);
    const [isMentorOpen, setIsMentorOpen] = useState(false);
    const [showQuiz, setShowQuiz] = useState(false);

    // Data States
    const [stats, setStats] = useState(null);
    const [livePeers, setLivePeers] = useState([]);
    const [contribData, setContribData] = useState(null);
    const [roomCache, setRoomCache] = useState({});
    const [toasts, setToasts] = useState([]);
    const [roomMessages, setRoomMessages] = useState({});
    const [myCourses, setMyCourses] = useState([]);
    const [triggerGoals, setTriggerGoals] = useState(0);

    const socketRef = useRef(null);
    const navigate = useNavigate();

    const addToast = (title, text) => {
        const id = Date.now();
        setToasts(prev => [...prev, { id, title, text }]);
        setTimeout(() => {
            setToasts(prev => prev.filter(t => t.id !== id));
        }, 4000);
    };

    // Global socket for notifications when modal is closed
    useEffect(() => {
        let socket;
        try {
            const socketUrl = import.meta.env.VITE_API_URL || "http://localhost:3001";
            socket = io(socketUrl, {
                reconnectionAttempts: 5,
                timeout: 10000
            });
            socketRef.current = socket;

            socket.on("connect", () => console.log("[SOCKET] Global connected"));
            socket.on("connect_error", (err) => console.error("[SOCKET] Connection failure", err));

            socket.on("new_message", (message) => {
                if (!message || !message.room_id) return;
                // If chat modal is NOT open for this room, show toast
                if (!activeChatPeer || activeChatPeer.id !== message.room_id) {
                    if (stats?.user?.id && message.sender_id !== stats.user.id) {
                        addToast(`New Message from ${message.sender_name || 'Scholar'}`, message.text || "New message received");
                        new Audio("https://assets.mixkit.co/active_storage/sfx/2354/2354-preview.mp3").play().catch(() => { });
                    }
                }
            });
        } catch (err) {
            console.error("[SOCKET] Initialization error", err);
        }

        return () => {
            if (socket) socket.disconnect();
        };
    }, [activeChatPeer, stats?.user?.id]);


    const loadData = () => {
        // Core Stats
        api.get("/dashboard/stats").then((res) => setStats(res.data)).catch(err => {
            if (err.response && err.response.status === 401) navigate('/login');
        });

        // Detailed Contribution & Portfolio Data
        api.get("/contributions/me").then((res) => setContribData(res.data)).catch(console.error);

        // Courses
        api.get("/enroll/me").then((res) => setMyCourses(res.data)).catch(err => {
            if (err.response && err.response.status === 401) navigate('/login');
        });
    };

    useEffect(() => {
        loadData();
        const interval = setInterval(loadData, 15000); // Poll every 15s for online status updates
        return () => clearInterval(interval);
    }, []);

    // Sync livePeers with stats
    useEffect(() => {
        if (stats?.onlinePeers) {
            setLivePeers(stats.onlinePeers);
        }
    }, [stats?.onlinePeers]);

    if (!stats) {
        return (
            <div className="flex items-center justify-center min-h-[60vh]">
                <div className="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-indigo-600"></div>
            </div>
        );
    }

    const { courses, progressPercent, streak: streakVal, companion, petHealth, weeklyActivity, weekDays, careerOracle } = stats;
    const streak = streakVal || stats.streak_count || 0;

    const inProgressCourse = Array.isArray(myCourses) ? myCourses.find((c) => c?.status === "in_progress") : null;
    const nextPlannedCourse = Array.isArray(myCourses) ? myCourses.find((c) => c?.status === "planned") : null;
    const suggestedCourse = inProgressCourse || nextPlannedCourse;

    const dataValues = weeklyActivity && weeklyActivity.length > 0 ? weeklyActivity : [0, 0, 0, 0, 0, 0, 0];
    const dataLabels = weekDays && weekDays.length > 0 ? weekDays : ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

    const onAction = async (type, data) => {
        // Handle asset-specific actions
        if (type === 'open_quiz') {
            setShowQuiz(true);
            return;
        }
        if (type === 'delete_asset') {
            try {
                await api.delete(`/contributions/${data.id}`);
                addToast("Asset Deleted", "The scholarly asset has been removed from the library.");
                loadData();
            } catch (err) {
                addToast("Error", "Failed to delete asset. Please try again.");
                console.error("Delete asset error:", err);
            }
        } else if (type === 'toggle_visibility') {
            try {
                await api.patch(`/contributions/${data.id}/visibility`);
                addToast("Visibility Updated", `Asset is now ${data.is_hidden ? 'public' : 'private'}.`);
                loadData();
            } catch (err) {
                addToast("Error", "Failed to update visibility. Please try again.");
                console.error("Toggle visibility error:", err);
            }
        } else if (type === 'review_asset') {
            setSelectedAssetForReview(data);
        } else if (type === 'open_library_feed') {
            setShowLibraryFeed(true);
        } else if (type === 'hide_from_specific') {
            const sid = window.prompt("Enter Student ID to block from viewing this asset:");
            if (sid) {
                try {
                    await api.post('/contributions/hide-from-student', { assetId: data.id, targetUserId: sid });
                    addToast("Access Restricted", `Asset hidden from student ${sid}.`);
                } catch (err) {
                    addToast("Error", "Failed to restrict access. Please try again.");
                    console.error("Hide from specific error:", err);
                }
            }
        } else {
            // Handle modal opening actions (upload_summary, transfer_asset, etc.)
            setActiveProtocolModal(type);
        }
    };



    return (
        <div

            className="max-w-[1800px] mx-auto px-8 space-y-12 animate-fade-in relative z-0 pb-20 overflow-hidden"
        >

            {/* Dynamic Parallax Background */}
            <div
                className="fixed inset-0 pointer-events-none opacity-5"
                style={{
                    x: bgX,
                    y: bgY
                }}
            >
                <div className="absolute top-[10%] left-[20%] w-[40%] h-[40%] bg-indigo-500/5 rounded-full blur-[120px]" />
                <div className="absolute top-[60%] left-[50%] w-[30%] h-[30%] bg-purple-500/5 rounded-full blur-[100px]" />
            </div>

            <div className="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-10 mb-20 relative z-10">
                <div>
                    <motion.h1
                        initial={{ opacity: 0, x: -20 }}
                        animate={{ opacity: 1, x: 0 }}
                        className="text-6xl font-black text-white tracking-tightest mb-4 outline-glow"
                    >
                        Dashboard
                    </motion.h1>
                    <motion.p
                        initial={{ opacity: 0 }}
                        animate={{ opacity: 1 }}
                        transition={{ delay: 0.3 }}
                        className="text-slate-400 text-2xl font-medium tracking-tight"
                    >
                        Precision engineering for the <span className="text-indigo-400 font-bold">dedicated scholar</span>.
                    </motion.p>
                </div>

                <div className="flex items-center gap-8">
                    <div className="flex flex-col items-end">
                        <motion.div
                            animate={{ scale: [1, 1.02, 1] }}
                            transition={{ duration: 2, repeat: Infinity }}
                            className="bg-orange-500/10 backdrop-blur-xl border border-orange-500/20 text-orange-400 px-10 py-6 rounded-[2.5rem] font-black flex items-center gap-6 shadow-2xl"
                        >
                            <Flame size={48} className="filter drop-shadow-[0_0_15px_rgba(249,115,22,0.6)]" />
                            <div className="flex flex-col">
                                <span className="text-3xl tracking-tighter outline-glow">{streak} Day Streak</span>
                                {stats.lastActive && <StreakTimer lastActive={stats.lastActive} />}
                            </div>
                        </motion.div>
                    </div>

                    <div className="flex items-center gap-6 studio-glass px-8 py-5 rounded-[2rem] hover:shadow-indigo-500/10 transition-shadow duration-700 cursor-pointer relative group"
                        onClick={() => {
                            setShowAdvisor(prev => !prev);
                            if (!showAdvisor) {
                                // Wait for render then scroll
                                setTimeout(() => document.getElementById('advisor-embed')?.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
                            }
                        }}
                    >
                        <div className="w-16 h-16 rounded-2xl bg-indigo-500/20 flex items-center justify-center text-4xl shadow-inner border border-indigo-500/20 relative text-indigo-400">
                            {companion?.icon ? <span>{companion.icon}</span> : "🎓"}
                            <div className="absolute -top-1 -right-1 w-4 h-4 bg-emerald-500 rounded-full border-2 border-[#020205] shadow-[0_0_10px_rgba(16,185,129,0.4)] animate-pulse"></div>
                        </div>
                        <div>
                            <p className="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-1">Animal Advisor</p>
                            <p className="text-xl font-bold text-white tracking-tight">{companion?.custom_name || companion?.name || 'Animal Advisor'}</p>
                            <div className="flex items-center gap-2 mt-1">
                                <span className="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                                <span className="text-[9px] font-black text-emerald-400/80 uppercase tracking-widest">Online Protocol Active</span>
                            </div>
                        </div>
                    </div>

                    {/* Vocation Readiness Ticker */}
                    {careerOracle && careerOracle.criticalPath.length > 0 ? (
                        <div className="flex items-center gap-6 bg-white/5 backdrop-blur-md border border-white/10 px-8 py-4 rounded-3xl group/ticker hover:border-gold/30 transition-all cursor-pointer" onClick={() => navigate('/profile/setup')}>
                            <div className="flex flex-col items-end">
                                <p className="text-[8px] font-black text-slate-500 uppercase tracking-[0.3em] mb-1">Career Alignment</p>
                                <p className="text-xl font-black text-white tracking-widest uppercase">{stats.user.dream_job}</p>
                            </div>
                            <div className="h-10 w-[1px] bg-white/10" />
                            <div className="flex flex-col">
                                <p className="text-[8px] font-black text-gold uppercase tracking-[0.3em] mb-1">Readiness</p>
                                <div className="flex items-baseline gap-2">
                                    <span className="text-2xl font-black text-gold">{careerOracle.percent}</span>
                                    <span className="text-[10px] font-black text-gold/40">%</span>
                                </div>
                            </div>
                        </div>
                    ) : (
                        <div className="flex items-center gap-6 bg-indigo-500/5 backdrop-blur-md border border-indigo-500/10 px-8 py-4 rounded-3xl hover:border-indigo-500/30 transition-all cursor-pointer group" onClick={() => navigate('/profile/setup')}>
                            <div className="w-10 h-10 rounded-full bg-indigo-500/10 flex items-center justify-center text-indigo-400 group-hover:scale-110 transition-transform">
                                <Target size={20} />
                            </div>
                            <div>
                                <p className="text-[8px] font-black text-indigo-400 uppercase tracking-[0.3em] mb-1">Oracle Status: Standby</p>
                                <p className="text-xs font-bold text-white uppercase tracking-widest">Set Career Target to initialize Mapping</p>
                            </div>
                        </div>
                    )}
                </div>
            </div>

            {/* COGNITIVE CONSTELLATION: THE KNOWLEDGE MAP */}
            <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{
                    opacity: 1,
                    y: 0,
                }}
                transition={{ duration: 1 }}
                className="mb-20 relative z-10"
            >
                <CognitiveConstellation />
            </motion.div>

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20 relative z-10">
                <motion.div
                    style={{ rotateX, rotateY }}
                    className="lg:col-span-2 hud-node p-16 flex flex-col lg:flex-row gap-16 items-center border-[#FFD700]/10"
                >
                    <div className="relative">
                        <p className="text-[11px] font-black tracking-[0.4em] text-indigo-400 uppercase mb-8 px-1">Progress Index</p>
                        <div className="flex items-baseline gap-4">
                            <span className="text-7xl font-black text-white tracking-tightest leading-none outline-glow">{progressPercent}</span>
                            <div className="flex flex-col">
                                <span className="text-4xl font-black text-indigo-500 opacity-50">%</span>
                                <p className="text-slate-400 font-bold mt-4 text-lg tracking-tight">Institutional<br />Progress Index</p>
                            </div>
                        </div>
                    </div>

                    <div className="flex-1 w-full space-y-12">
                        <div className="flex justify-between items-end">
                            <div>
                                <p className="text-[11px] font-black text-slate-500 uppercase tracking-[0.3em] mb-4">Cohort Performance High</p>
                                <div className="flex gap-2 items-center">
                                    <div className="w-10 h-10 rounded-full bg-indigo-500/10 flex items-center justify-center text-xl shadow-inner border border-indigo-500/20 text-indigo-400">
                                        📊
                                    </div>
                                    <span className="text-slate-400 text-sm font-bold ml-2">
                                        {progressPercent}% Complete
                                    </span>
                                </div>
                            </div>
                            <span className="text-4xl font-black text-indigo-400">{progressPercent}%</span>
                        </div>
                        <div className="h-4 bg-white/5 rounded-full overflow-hidden p-1 shadow-inner relative">
                            <motion.div
                                initial={{ width: 0 }}
                                animate={{ width: `${progressPercent}%` }}
                                transition={{ duration: 2, ease: [0.22, 1, 0.36, 1] }}
                                className="h-full rounded-full relative overflow-hidden"
                                style={{ background: 'linear-gradient(90deg, #6366f1, #a855f7)' }}
                            >
                                <motion.div
                                    animate={{ x: ['0%', '100%'] }}
                                    transition={{ duration: 2, repeat: Infinity, ease: 'linear' }}
                                    className="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent w-40"
                                />
                            </motion.div>
                        </div>
                    </div>
                </motion.div>

                <motion.div
                    style={{ rotateX: rotateX_intense, rotateY: rotateY_intense }}
                    className="lg:col-span-1 hud-node p-12 bg-gradient-to-br from-indigo-50/10 to-purple-50/5 flex flex-col justify-between group overflow-hidden border-indigo-200/20"
                >
                    <div className="absolute top-0 right-0 w-40 h-40 bg-indigo-400/20 rounded-full blur-[60px] -translate-y-1/2 translate-x-1/2 group-hover:bg-indigo-400/30 transition-all duration-700" />
                    <div className="relative z-10">
                        <p className="text-[10px] font-black text-indigo-300 uppercase tracking-[0.3em] mb-8">Active Protocols</p>
                        <div className="space-y-6">
                            {[
                                { label: 'Summaries Synthetic', val: stats.stats?.summaries || 0, icon: "📝" },
                                { label: 'Cognitive Cheatsheets', val: stats.stats?.cheatsheets || 0, icon: "⚡" },
                                { label: 'Scholarly Feedback', val: stats.stats?.reviews || 0, icon: "💬" },
                            ].map((item, idx) => (
                                <div key={idx} className="flex justify-between items-center bg-white/10 p-5 rounded-[1.5rem] border border-white/20 hover:border-indigo-300/40 hover:bg-white/15 transition-all">
                                    <div className="flex items-center gap-4">
                                        <span className="text-slate-200">{item.icon}</span>
                                        <span className="text-[10px] font-black uppercase text-slate-300 tracking-widest">{item.label}</span>
                                    </div>
                                    <span className="text-2xl font-black text-white">{item.val}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                    <button
                        onClick={() => setShowLibraryFeed(true)}
                        className="w-full mt-10 py-5 bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-300/30 hover:border-indigo-300/50 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] text-indigo-100 hover:text-white transition-all active:scale-95 shadow-lg"
                    >
                        Access Repository ↗
                    </button>
                </motion.div>
            </div >

            <div className="mb-24">
                <IntellectualForge
                    stats={stats}
                    contribData={contribData}
                    onAction={onAction}
                    currentUserId={stats.user?.id}
                />
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-4 gap-12 mb-20">
                <div className="lg:col-span-3">
                    <motion.div
                        style={{ rotateX, rotateY }}
                        className="hud-node p-12 border-white/5 shadow-2xl relative"
                    >
                        <div className="absolute inset-0 bg-indigo-500/5 animate-pulse" />
                        <div className="flex justify-between items-center mb-12">
                            <div>
                                <p className="text-[10px] font-black uppercase tracking-[0.4em] text-indigo-400 mb-2">Activity Log</p>
                                <h3 className="text-3xl font-black text-white tracking-tightest outline-glow">Intellectual Velocity</h3>
                            </div>
                            <div className="flex gap-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">
                                <div className="flex items-center gap-2"><span className="w-2.5 h-2.5 rounded-full bg-indigo-500 shadow-[0_0_10px_rgba(99,102,241,0.5)]"></span> Energy Delta</div>
                            </div>
                        </div>
                        <div className="h-56 relative w-full">
                            <LineChart data={dataValues} labels={dataLabels} color="#6366f1" />
                        </div>
                    </motion.div>
                </div>

                <div className="lg:col-span-1">
                    <CampusLounge
                        onSelectRoom={(room) => setActiveChatPeer(room)}
                        onlineScholars={livePeers || []}
                    />
                </div>
            </div >

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20">
                <div className="lg:col-span-2">
                    {/* Missions Board - Zenith Style */}
                    <motion.div
                        style={{ rotateX, rotateY }}
                        className="hud-node p-12 relative overflow-hidden group border-white/10"
                    >
                        <div className="absolute top-0 right-0 p-16 opacity-[0.05] grayscale pointer-events-none transition-transform group-hover:rotate-12 duration-1000 text-white">
                            <School size={160} />
                        </div>
                        <div className="flex justify-between items-center mb-12 relative z-10">
                            <div>
                                <p className="text-[10px] font-black tracking-[0.4em] text-indigo-400 uppercase mb-2">Workspace</p>
                                <h2 className="text-5xl font-black text-white tracking-tightest outline-glow">Mission Board</h2>
                            </div>
                        </div>
                        <DailyGoalsList trigger={triggerGoals} />
                    </motion.div>
                </div>

                <div className="flex flex-col gap-8">
                    <div className="bg-indigo-500/10 border border-indigo-500/20 rounded-[2.5rem] p-10 shadow-2xl flex-1 flex flex-col justify-center relative overflow-hidden group">
                        <div className="absolute -right-4 -bottom-4 text-indigo-400 opacity-[0.1] group-hover:scale-125 transition-transform duration-1000">
                            <Sparkles size={64} />
                        </div>
                        <p className="text-indigo-200 text-2xl font-black leading-tight tracking-tight relative z-10 flex items-center gap-4">
                            {streak >= 7 ? <Award className="text-gold" /> : streak >= 3 ? <Zap className="text-orange-400" /> : <Target className="text-indigo-400" />}
                            <span>{streak >= 7 ? "You’re building a powerful learning habit!" : streak >= 3 ? "Momentum is forming." : "Small steps daily create big results."}</span>
                        </p>
                    </div>

                    <div
                        className="bg-[#0a0c20]/40 border border-white/5 rounded-[2.5rem] p-10 shadow-2xl flex-1 flex flex-col justify-between group cursor-pointer hover:border-indigo-500/50 transition-all relative overflow-hidden"
                        onClick={() => suggestedCourse ? navigate(`/courses/${suggestedCourse.id}`) : navigate("/courses")}
                    >
                        <div className="relative z-10">
                            <p className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] mb-3">Next Up</p>
                            <h3 className="text-2xl font-black text-white group-hover:text-indigo-400 transition-colors uppercase tracking-tight">
                                {suggestedCourse ? suggestedCourse.name : "Browse Courses"}
                            </h3>
                        </div>
                        <div className="flex justify-end mt-6 relative z-10">
                            <div className="bg-white/5 text-slate-500 p-4 rounded-2xl group-hover:bg-indigo-600 group-hover:text-white transition-all border border-white/5 shadow-2xl font-black">
                                <ChevronRight size={20} />
                            </div>
                        </div>
                    </div>

                    <AnimatePresence>
                        {/* Advisor removed from here to be placed in modal */}
                    </AnimatePresence>
                </div>
            </div >

            {/* Feeding task removed */}

            <AnimatePresence>
                {activeProtocolModal && (
                    <div className="fixed inset-0 z-[70] flex items-center justify-center bg-[#03040b]/90 backdrop-blur-2xl p-4">
                        <ScholarlyProtocolModal
                            type={activeProtocolModal}
                            onClose={() => setActiveProtocolModal(null)}
                            onSubmitted={() => {
                                addToast("Asset Synchronized", "Your document has been pushed to the Institutional Library.");
                                setActiveProtocolModal(null);
                                loadData();
                            }}
                        />
                    </div>
                )}
            </AnimatePresence>

            <AnimatePresence>
                {selectedAssetForReview && (
                    <div className="fixed inset-0 z-[70] flex items-center justify-center bg-[#03040b]/90 backdrop-blur-2xl p-4">
                        <ReviewAssetModal
                            asset={selectedAssetForReview}
                            onClose={() => setSelectedAssetForReview(null)}
                            onSubmitted={() => {
                                addToast("Review Logged", "Your feedback has been synchronized with the scholarly record.");
                                setSelectedAssetForReview(null);
                                loadData();
                            }}
                        />
                    </div>
                )}
            </AnimatePresence>

            <AnimatePresence>
                {showLibraryFeed && (
                    <div
                        className="fixed inset-0 z-[80] flex items-center justify-center bg-black/60 backdrop-blur-xl p-8"
                        onClick={() => setShowLibraryFeed(false)}
                    >
                        <LibraryFullFeedModal
                            assets={contribData?.cheatsheets || []}
                            currentUserId={stats?.user?.id}
                            onClose={() => setShowLibraryFeed(false)}
                            onReview={(asset) => {
                                setShowLibraryFeed(false);
                                setSelectedAssetForReview(asset);
                            }}
                            onAction={async (type, data) => {
                                if (type === 'delete_asset') {
                                    if (window.confirm("Scholarly expunge protocol?")) {
                                        await api.delete(`/contributions/${data.id}`);
                                        loadData();
                                    }
                                } else if (type === 'toggle_visibility') {
                                    await api.patch(`/contributions/${data.id}/visibility`);
                                    loadData();
                                } else if (type === 'hide_from_specific') {
                                    const sid = window.prompt("Student ID to block:");
                                    if (sid) await api.post('/contributions/hide-from-student', { assetId: data.id, targetUserId: sid });
                                }
                            }}
                        />
                    </div>
                )}
            </AnimatePresence>

            <AnimatePresence>
                {activeChatPeer && (
                    <div className="fixed inset-0 z-[60] flex items-center justify-center bg-[#03040b]/90 backdrop-blur-2xl p-4">
                        <CampusChat
                            activeRoom={activeChatPeer}
                            currentUser={stats?.user}
                            roomCache={roomCache}
                            setRoomCache={setRoomCache}
                            onClose={() => setActiveChatPeer(null)}
                        />
                    </div>
                )}
            </AnimatePresence>

            <AnimatePresence>
                {isMentorOpen && (
                    <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-md p-4">
                        <AiMentorModal onClose={() => setIsMentorOpen(false)} onGoalSet={() => setTriggerGoals(n => n + 1)} />
                    </motion.div>
                )}
            </AnimatePresence>

            <AnimatePresence>
                {showAdvisor && (
                    <div className="fixed inset-0 z-[80] flex items-center justify-center bg-black/80 backdrop-blur-md p-4 animate-fade-in">
                        <div className="relative w-full max-w-5xl">
                            <button
                                onClick={() => setShowAdvisor(false)}
                                className="absolute -top-12 right-0 text-white/50 hover:text-white transition-colors"
                            >
                                <X size={32} />
                            </button>
                            <PetSelector
                                onSelect={(pet) => {
                                    loadData();
                                    // Optional: keep open or close
                                }}
                                onClose={() => setShowAdvisor(false)}
                            />
                        </div>
                    </div>
                )}
            </AnimatePresence>

            {/* CompanionChat removed - now global in MainLayout */}
            {/* Toasts */}
            <div className="fixed bottom-12 right-12 z-[100] flex flex-col gap-6 w-96 pointer-events-none">
                <AnimatePresence>
                    {toasts.map(toast => (
                        <motion.div
                            key={toast.id}
                            initial={{ x: 100, opacity: 0, scale: 0.9 }}
                            animate={{ x: 0, opacity: 1, scale: 1 }}
                            exit={{ x: 100, opacity: 0, scale: 0.9 }}
                            className="bg-[#0a0c20]/90 border border-indigo-500/30 rounded-[1.5rem] p-8 shadow-2xl backdrop-blur-xl pointer-events-auto flex items-start gap-5"
                        >
                            <div className="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 border border-indigo-500/20 shadow-inner flex-shrink-0">
                                <Bell size={18} />
                            </div>
                            <div>
                                <p className="text-[10px] font-black text-indigo-400 uppercase tracking-[0.3em] mb-2">{toast.title}</p>
                                <p className="text-white text-sm font-black tracking-tight leading-relaxed">{toast.text}</p>
                            </div>
                        </motion.div>
                    ))}
                </AnimatePresence>
            </div>
            {showQuiz && (
                <QuizModal
                    isOpen={showQuiz}
                    onClose={() => setShowQuiz(false)}
                    topic={null} // Default to General for now, or could pass user major
                />
            )}
        </div >
    );
};

export default Dashboard;

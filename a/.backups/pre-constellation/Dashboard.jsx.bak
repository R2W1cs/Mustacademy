const StatCard = ({ title, value, icon, color, trend }) => {
    // Override color mapping to Gold for top-tier stats

    return (
        <motion.div
            whileHover={{ y: -8, scale: 1.02 }}
            transition={{ duration: 0.5, ease: [0.22, 1, 0.36, 1] }}
            className="hud-node p-10 group border-white/5 hover:border-gold/30"
        >
            <div className="flex justify-between items-start mb-8">
                <div className="w-16 h-16 rounded-[1.5rem] bg-gradient-to-br from-[#FFD700]/20 to-[#B8860B]/10 flex items-center justify-center text-3xl shadow-[0_0_20px_rgba(255,215,0,0.15)] group-hover:shadow-[0_0_40px_rgba(255,215,0,0.4)] transition-all duration-700 text-[#FFD700]">
                    {icon}
                </div>
                {trend && (
                    <span className={`text-[10px] font-black px-4 py-2 rounded-full uppercase tracking-widest ${trend > 0 ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-rose-500/10 text-rose-400 border border-rose-500/20'}`}>
                        {trend > 0 ? '+' : ''}{trend}%
                    </span>
                )}
            </div>
            <div>
                <p className="text-[11px] font-black text-slate-500 uppercase tracking-[0.4em] mb-3">{title}</p>
                <div className="flex items-baseline gap-2">
                    <h4 className="text-5xl font-black text-white tracking-tightest leading-none outline-glow">
                        {value}
                    </h4>
                </div>
            </div>

            {/* Animated Corner Glow */}
            <div className="absolute -bottom-10 -right-10 w-24 h-24 bg-[#FFD700]/10 rounded-full blur-[40px] opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
        </motion.div>
    );
};

const LineChart = ({ data, color = "#FFD700", labels = [] }) => {
    const minData = Math.min(...data, 0);
    const maxData = Math.max(...data, 10);
    const range = maxData - minData || 1;
    const height = 40;
    const padding = 10;

    const getX = (i) => (i / (data.length - 1)) * 300;
    const getY = (v) => 60 - padding - ((v - minData) / range) * height;

    const points = data.map((v, i) => ({ x: getX(i), y: getY(v) }));

    // Generate cubic bezier path for a "cute" smooth curve
    let curvePath = `M ${points[0].x},${points[0].y}`;
    for (let i = 0; i < points.length - 1; i++) {
        const p0 = points[i];
        const p1 = points[i + 1];
        const cp1x = p0.x + (p1.x - p0.x) / 2;
        const cp1y = p0.y;
        const cp2x = p0.x + (p1.x - p0.x) / 2;
        const cp2y = p1.y;
        curvePath += ` C ${cp1x},${cp1y} ${cp2x},${cp2y} ${p1.x},${p1.y}`;
    }

    const areaPath = `${curvePath} L 300, 60 L 0, 60 Z`;

    return (
        <div className="relative h-full w-full group flex flex-col">
            <div className="flex-1 min-h-0 relative">
                <svg className="w-full h-full overflow-visible" viewBox="0 0 300 60" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id={`gradient-gold`} x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stopColor="#FFD700" stopOpacity="0.3" />
                            <stop offset="100%" stopColor="#FFD700" stopOpacity="0" />
                        </linearGradient>
                        <filter id="glow-gold">
                            <feGaussianBlur stdDeviation="3" result="coloredBlur" />
                            <feMerge>
                                <feMergeNode in="coloredBlur" />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                    </defs>

                    {/* Subtle area fill */}
                    <motion.path
                        d={areaPath}
                        fill={`url(#gradient-gold)`}
                        initial={{ opacity: 0 }}
                        animate={{ opacity: 1 }}
                        transition={{ duration: 2 }}
                    />

                    {/* Smooth bezier line */}
                    <motion.path
                        d={curvePath}
                        fill="none"
                        stroke="#FFD700"
                        strokeWidth="4"
                        strokeLinecap="round"
                        strokeLinejoin="round"
                        filter="url(#glow-gold)"
                        initial={{ pathLength: 0, opacity: 0 }}
                        animate={{ pathLength: 1, opacity: 1 }}
                        transition={{ duration: 2, ease: [0.22, 1, 0.36, 1] }}
                    />

                    {/* Glowing data points */}
                    {points.map((p, i) => (
                        <motion.circle
                            key={i}
                            cx={p.x}
                            cy={p.y}
                            r="5"
                            fill="#03040b"
                            stroke="#FFD700"
                            strokeWidth="3"
                            initial={{ scale: 0 }}
                            animate={{ scale: 1 }}
                            transition={{ delay: 1 + i * 0.1, type: 'spring', stiffness: 200 }}
                            className="cursor-pointer transition-all"
                            style={{ filter: `drop-shadow(0 0 8px #FFD700)` }}
                        />
                    ))}

                    {/* Baseline */}
                    <line
                        x1="0" y1={getY(0)}
                        x2="300" y2={getY(0)}
                        stroke="white"
                        strokeOpacity="0.1"
                        strokeWidth="1"
                        strokeDasharray="4 4"
                    />
                </svg>
            </div>
            {labels.length > 0 && (
                <div className="flex justify-between mt-6 px-2">
                    {labels.map((label, idx) => (
                        <span key={idx} className="text-[9px] font-black text-slate-500 uppercase tracking-[0.2em]">{label}</span>
                    ))}
                </div>
            )}
        </div>
    );
};

const StreakTimer = ({ lastActive }) => {
    const [timeLeft, setTimeLeft] = useState("");
    const [status, setStatus] = useState("loading");

    useEffect(() => {
        const updateTimer = () => {
            const now = new Date();
            const last = new Date(lastActive);
            const diffMs = now - last;
            const diffHours = diffMs / 36e5;

            if (diffHours < 24) {
                const hoursLeft = Math.ceil(24 - diffHours);
                setTimeLeft(`${hoursLeft}h until next point`);
                setStatus("cooldown");
            } else if (diffHours < 48) {
                const hoursLeft = Math.ceil(48 - diffHours);
                setTimeLeft(`${hoursLeft}h left to save streak!`);
                setStatus("active");
                if (diffHours > 44) setStatus("danger");
            } else {
                setTimeLeft("Streak lost");
                setStatus("lost");
            }
        };

        updateTimer();
        const interval = setInterval(updateTimer, 60000);
        return () => clearInterval(interval);
    }, [lastActive]);

    const getColor = () => {
        switch (status) {
            case "cooldown": return "text-gray-400";
            case "active": return "text-[#FFD700] font-bold shadow-gold";
            case "danger": return "text-red-500 font-bold animate-pulse";
            default: return "text-gray-400";
        }
    };

    return <p className={`text-xs mt-1 mr-2 ${getColor()}`}>{timeLeft}</p>;
};

const DailyGoalsList = ({ trigger }) => {
    const [goals, setGoals] = useState([]);
    const [loading, setLoading] = useState(true);
    const [submitGoal, setSubmitGoal] = useState(null);
    const [activeTab, setActiveTab] = useState("todo"); // todo or history

    useEffect(() => {
        setLoading(true);
        api.get("/ai/goals")
            .then(res => setGoals(res.data))
            .catch(console.error)
            .finally(() => setLoading(false));
    }, [trigger]);

    const completeGoal = (id) => {
        api.post("/ai/complete", { goalId: id }).then(() => {
            // Optistically update local state or just refetch
            api.get("/ai/goals").then(res => setGoals(res.data));
        });
    };

    if (loading) return (
        <div className="flex justify-center py-10">
            <div className="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-white/50"></div>
        </div>
    );

    const activeGoals = Array.isArray(goals) ? goals.filter(g => !g.is_completed) : [];
    const completedGoals = Array.isArray(goals) ? goals.filter(g => g.is_completed) : [];
    const displayGoals = activeTab === "todo" ? activeGoals : completedGoals;

    return (
        <>
            {/* Tabs */}
            <div className="flex gap-8 mb-8 relative z-10 border-b border-white/5 pb-4">
                <button
                    onClick={() => setActiveTab("todo")}
                    className={`pb-2 px-1 text-[10px] font-black uppercase tracking-[0.3em] transition-all relative ${activeTab === "todo" ? "text-indigo-400" : "text-slate-500 hover:text-slate-300"}`}
                >
                    To-Do ({activeGoals.length})
                    {activeTab === "todo" && <motion.div layoutId="tabUnderline" className="absolute bottom-[-1px] left-0 right-0 h-0.5 bg-indigo-400 shadow-[0_0_10px_rgba(99,102,241,0.5)]" />}
                </button>
                <button
                    onClick={() => setActiveTab("history")}
                    className={`pb-2 px-1 text-[10px] font-black uppercase tracking-[0.3em] transition-all relative ${activeTab === "history" ? "text-indigo-400" : "text-slate-500 hover:text-slate-300"}`}
                >
                    History ({completedGoals.length})
                    {activeTab === "history" && <motion.div layoutId="tabUnderline" className="absolute bottom-[-1px] left-0 right-0 h-0.5 bg-indigo-400 shadow-[0_0_10px_rgba(99,102,241,0.5)]" />}
                </button>
            </div>

            <div className="space-y-6 relative z-10">
                <AnimatePresence mode="popLayout">
                    {displayGoals.map(g => (
                        <motion.div
                            key={g.id}
                            initial={{ opacity: 0, y: 10 }}
                            animate={{ opacity: 1, y: 0 }}
                            exit={{ opacity: 0, scale: 0.95 }}
                            className={`p-8 rounded-[2rem] border transition-all duration-300 ${g.is_completed
                                ? "bg-[#0a0c20]/20 border-white/5 opacity-50"
                                : "bg-white/5 border-white/10 hover:border-indigo-500/50 shadow-2xl shadow-black/40 group"
                                }`}
                        >
                            <div className="flex justify-between items-start mb-6">
                                <div className="flex-1">
                                    <div className="flex items-center gap-3 mb-3">
                                        <span className={`w-2.5 h-2.5 rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)] ${g.ai_grade >= 80 ? 'bg-gold-gradient shadow-gold' : 'bg-indigo-500'}`}></span>
                                        <p className={`text-[9px] font-black tracking-[0.4em] uppercase ${g.ai_grade >= 80 ? 'text-gold-gradient' : 'text-indigo-300/50'}`}>Objective</p>
                                    </div>
                                    <p className={`font-black leading-tight tracking-tight ${g.is_completed ? "text-slate-600 line-through" : "text-white text-2xl"}`}>
                                        {g.description}
                                    </p>
                                </div>
                                {!g.is_completed && (
                                    <button
                                        onClick={() => completeGoal(g.id)}
                                        className="text-white/20 hover:text-rose-500 transition-colors p-2 rounded-xl hover:bg-white/5"
                                    >
                                        <X size={20} />
                                    </button>
                                )}
                            </div>

                            <div className="flex flex-wrap items-center gap-6 py-5 border-t border-white/5">
                                <div className="flex items-center gap-3">
                                    <div className="w-10 h-10 rounded-2xl bg-white/5 flex items-center justify-center text-sm shadow-inner text-indigo-400">
                                        <Clock size={18} />
                                    </div>
                                    <div>
                                        <p className="text-[8px] font-black text-indigo-300/50 uppercase tracking-widest">Deadline</p>
                                        <p className="text-[10px] font-black text-white uppercase tracking-tighter">{new Date(g.deadline).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</p>
                                    </div>
                                </div>

                                {g.ai_grade !== null && (
                                    <div className="flex items-center gap-3">
                                        <div className={`w-10 h-10 rounded-2xl flex items-center justify-center text-sm border shadow-inner ${g.ai_grade >= 80 ? 'bg-[#FFD700]/10 text-[#FFD700] border-[#FFD700]/30 shadow-gold' : 'bg-indigo-500/10 text-indigo-300 border-indigo-500/20'}`}>
                                            {g.ai_grade >= 80 ? <Award size={18} /> : <Star size={18} />}
                                        </div>
                                        <div>
                                            <p className={`text-[8px] font-black uppercase tracking-widest ${g.ai_grade >= 80 ? 'text-[#FFD700]/70' : 'text-indigo-300/50'}`}>Performance</p>
                                            <p className={`text-[10px] font-black ${g.ai_grade >= 80 ? 'text-gold-gradient' : 'text-indigo-400'}`}>{g.ai_grade}% SCORE</p>
                                        </div>
                                    </div>
                                )}
                            </div>

                            <div className="flex gap-4 mt-4">
                                <button
                                    onClick={() => setSubmitGoal(g)}
                                    className={`flex-1 py-4 rounded-2xl text-[10px] font-black tracking-[0.3em] uppercase transition-all shadow-2xl ${g.submitted_at
                                        ? g.ai_grade >= 80
                                            ? "bg-gold-gradient text-black hover:brightness-110 shadow-gold border border-gold"
                                            : "bg-white/5 text-slate-500 hover:bg-white/10 border border-white/5"
                                        : "bg-white text-slate-900 hover:bg-indigo-600 hover:text-white"
                                        }`}
                                >
                                    {g.submitted_at ? "Review Work" : "Execute Mission"}
                                </button>
                                {!g.submitted_at && !g.is_completed && (
                                    <button
                                        onClick={() => completeGoal(g.id)}
                                        className="px-8 py-4 bg-transparent border border-white/10 text-slate-500 hover:border-indigo-500 hover:text-white rounded-2xl text-[10px] font-black tracking-[0.3em] uppercase transition-all"
                                    >
                                        Done
                                    </button>
                                )}
                            </div>
                        </motion.div>
                    ))}
                </AnimatePresence>

                {displayGoals.length === 0 && (
                    <div className="text-center py-20 text-gray-500 bg-black/20 rounded-[2.5rem] border border-dashed border-white/5">
                        <div className="flex justify-center mb-6 opacity-20 text-6xl">
                            {activeTab === 'todo' ? <Target size={64} /> : <BookOpen size={64} />}
                        </div>
                        <p className="font-black text-white/40 uppercase tracking-widest text-sm">{activeTab === 'todo' ? 'All Objectives Secured' : 'No mission history'}</p>
                        <p className="text-[9px] mt-2 font-black uppercase tracking-[0.3em] opacity-30 px-10 leading-relaxed">
                            {activeTab === 'todo' ? 'Consult with the Mentor to initialize new protocols.' : 'Initialize your first procedure to log records.'}
                        </p>
                    </div>
                )}
            </div>

            <AnimatePresence>
                {submitGoal && (
                    <div className="fixed inset-0 z-[60] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4">
                        <SubmitWorkModal
                            goal={submitGoal}
                            onClose={() => setSubmitGoal(null)}
                            onSubmitted={() => {
                                setSubmitGoal(null);
                                api.get("/ai/goals").then(res => setGoals(res.data));
                            }}
                        />
                    </div>
                )}
            </AnimatePresence>
        </>
    );
};


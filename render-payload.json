{
  "type": "web_service",
  "name": "mustacademy-backend",
  "ownerId": "tea-d6qldk450q8c73bki8i0",
  "repo": "https://github.com/R2W1cs/Mustacademy",
  "autoDeploy": "yes",
  "branch": "main",
  "rootDir": "server",
  "serviceDetails": {
    "env": "node",
    "plan": "free",
    "region": "frankfurt",
    "envSpecificDetails": {
      "buildCommand": "npm install",
      "startCommand": "npm start"
    },
    "envVars": [
      {"key": "NODE_ENV", "value": "production"},
      {"key": "PORT", "value": "10000"},
      {"key": "DATABASE_URL", "value": "YOUR_DATABASE_URL_HERE"},
      {"key": "JWT_SECRET", "value": "YOUR_JWT_SECRET_HERE"},
      {"key": "FRONTEND_URL", "value": "https://mustacademy-frontend.vercel.app"}
    ]
  }
}
